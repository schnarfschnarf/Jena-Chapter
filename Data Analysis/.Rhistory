library(ggpmisc)
theme_set(theme_custom())
#load synthesis dataset
synthDat <- read_xlsx("C:/Users/mm68tulo/Desktop/Jena Chapter/Data Analysis/1_Data/economic_MF_final.xlsx") %>%
filter(sowndiv < 60) %>%  #remove 60 species plots
mutate(block = as.factor(block))
knitr::opts_chunk$set(warning=FALSE, message=FALSE, echo=TRUE, fig.width=10, fig.height=6, dpi=300, cache=TRUE, cache.lazy=FALSE, cache.path="cache/", fig.path="figures/", out.width="100%", out.height="100%")
source("C:/Users/mm68tulo/Documents/R/functions/myfunctions.R")
theme_set(theme_custom())
rp_quad <- lm(RP ~ sowndiv + I(sowndiv^2), data = synthDat)
dRdB <- function(B) {
b <- coef(rp_quad)
b[["sowndiv"]] + 2 * b[["I(sowndiv^2)"]] * B
}
by_SR <- by_SR %>%
dplyr::mutate(
dRdB = dRdB(sowndiv),
I_raw = sowndiv * dRdB,          # this is B * dR/dB (likely negative)
I_pos = -sowndiv * dRdB          # optional: positive "insurance strength" index
)
fit_rp <- brm(
RP ~ sowndiv + I(sowndiv^2),
data = synthDat,
family = gaussian(),
chains = 4, cores = 4, iter = 4000
)
#trial
by_SR <- data.frame(
sowndiv = sort(unique(synthDat$sowndiv))
)
by_SR <- by_SR %>%
dplyr::mutate(
dRdB = dRdB(sowndiv),
I_raw = sowndiv * dRdB,          # this is B * dR/dB (likely negative)
I_pos = -sowndiv * dRdB          # optional: positive "insurance strength" index
)
View(by_SR)
post <- as_draws_df(fit_rp)
# brms coefficient names are typically: b_Intercept, b_sowndiv, b_IsowndivE2
b1 <- post$b_sowndiv
b2 <- post$b_IsowndivE2
B_vals <- sort(unique(by_SR$sowndiv))
I_draws <- lapply(B_vals, function(B){
dRdB_draw <- b1 + 2 * b2 * B
data.frame(
sowndiv = B,
I_raw = B * dRdB_draw,
I_pos = -B * dRdB_draw
)
}) |> dplyr::bind_rows(.id = "draw")
I_post <- I_draws %>%
dplyr::group_by(sowndiv) %>%
dplyr::summarise(
I_raw_mean = mean(I_raw),
I_raw_lwr  = quantile(I_raw, 0.025),
I_raw_upr  = quantile(I_raw, 0.975),
I_pos_mean = mean(I_pos),
I_pos_lwr  = quantile(I_pos, 0.025),
I_pos_upr  = quantile(I_pos, 0.975),
.groups = "drop"
)
View(I_post)
p_sown_I <- ggplot(
I_post,
aes(x = factor(sowndiv), y = I_pos_mean)
) +
geom_point(
size   = 2.5,
shape  = 21,
fill   = "#0072B2",
colour = "#004C70",
stroke = 0.4
) +
geom_errorbar(
aes(ymin = I_pos_lwr, ymax = I_pos_upr),
width     = 0.15,
colour    = "#004C70",
linewidth = 0.5
) +
geom_hline(
yintercept = 0,
linetype   = "dashed",
colour     = "grey50",
linewidth  = 0.6
) +
scale_x_discrete(
limits = c("1", "2", "4", "8", "16")
) +
labs(
x = "Sown plant species richness",
y = expression("Insurance strength index " * I * " = " * -B * frac(dR, dB))
) +
coord_cartesian(clip = "off") +
theme_custom() +
theme(
aspect.ratio = 0.6
)
p_sown_I
fit_rp <- brm(
RP ~ log2_SR,
data = synthDat,
family = gaussian(),
prior = prior(normal(0, 20), class = "b"),
chains = 4, cores = 4, iter = 4000
)
synthDat <- synthDat %>%
dplyr::mutate(log2_SR = log2(sowndiv))
fit_rp <- brm(
RP ~ log2_SR,
data = synthDat,
family = gaussian(),
prior = prior(normal(0, 20), class = "b"),
chains = 4, cores = 4, iter = 4000
)
post <- as_draws_df(fit_rp)
beta <- post$b_log2_SR
mean(beta)
quantile(beta, c(0.025, 0.5, 0.975))
newdat <- data.frame(
log2_SR = seq(0, 4, length.out = 100)
)
pred <- fitted(fit_rp, newdata = newdat, summary = TRUE)
plotdat <- cbind(newdat, pred)
ggplot(plotdat, aes(x = log2_SR, y = Estimate)) +
geom_line(colour = "#0072B2") +
geom_ribbon(
aes(ymin = Q2.5, ymax = Q97.5),
alpha = 0.15,
fill = "#0072B2"
) +
labs(
x = expression(log[2]*"(species richness)"),
y = expression("Risk premium (€ ha"^{-1}*" yr"^{-1}*")")
) +
theme_custom()
I_doubling_draws <- -beta
I_doubling_summary <- c(
mean = mean(I_doubling_draws),
lwr  = quantile(I_doubling_draws, 0.025),
upr  = quantile(I_doubling_draws, 0.975)
)
I_doubling_summary
