# Economic MF vs mean realised plant diversity with 3 price scenarios
p_sown_total <- ggplot() +
# raw data
geom_point(
data   = synthDat,
aes(x  = sowndiv, y = costs_total_mid),
alpha  = 0.5,
size   = 2,
shape  = 21,
fill   = "#0072B2",
colour = "#004C70",
stroke = 0.4
) +
# horizontal reference line at 0
geom_hline(
yintercept = 0,
colour     = "grey80",
linewidth  = 0.6
) +
# ribbon only for baseline scenario (to avoid clutter)
geom_ribbon(
data = filter(plot_sown_total_all, scenario == "Mid price (default)"),
aes(x = sowndiv, ymin = lower__, ymax = upper__),
fill  = "#0072B2",
alpha = 0.15
) +
# lines for all three scenarios
geom_line(
data = plot_sown_total_all,
aes(x = sowndiv, y = estimate__, colour = scenario, linetype = scenario),
linewidth = 0.9
) +
scale_colour_manual(
name   = "Price scenario",
values = c(
"Mid price (default)"  = "#0072B2",  # solid blue
"Low price" = "#009E73",  # green
"High price"= "#E69F00"   # orange
)
) +
scale_linetype_manual(
name   = "Price scenario",
values = c(
"Mid price (default)"  = "solid",
"Low price" = "dashed",
"High price"= "dotted"
)
) +
scale_x_continuous(
breaks = c(1,2, 4, 8, 16),
expand = expansion(mult = c(0.02, 0.02))
) +
scale_y_continuous(
breaks = c(-1500, -1000,-500, 0, 500, 1000, 1500)
) +
labs(
x = "Sown plant diversity (species)",
y = "Economic multifunctionality (€/ha/yr)"
) +
coord_cartesian(clip = "off") +
theme_custom() +
theme(
aspect.ratio     = 0.6,
legend.position  = "bottom",
legend.direction = "horizontal",
legend.title     = element_text(size = 12),
legend.text      = element_text(size = 11),
legend.box       = "horizontal",
legend.spacing.x = unit(4, "pt")
)
p_sown_total
# prepare data for combined plot
raw_sown_total_all <- synthDat %>%
select(sowndiv, costs_total_mid, costs_total_lo, costs_total_hi) %>%
pivot_longer(
cols      = c(costs_total_mid, costs_total_lo, costs_total_hi),
names_to  = "scenario_raw",
values_to = "economic_mf"
) %>%
mutate(
scenario = dplyr::recode(
scenario_raw,
"costs_total_mid" = "Mid price (default)",
"costs_total_lo"  = "Low price",
"costs_total_hi"  = "High price"
)
)
