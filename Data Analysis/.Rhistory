mutate(mean_org_20 = mean(Corg_Soil), mean_inorg_20 = mean(Cinorg_Soil)) %>%
distinct(plotcode, mean_org_20, mean_inorg_20) %>%
mutate(mean_C_20 = mean_org_20 + mean_inorg_20)
# create a new column with mean C across layers per plot for 2002
