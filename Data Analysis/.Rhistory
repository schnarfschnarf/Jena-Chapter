# plot the marginal effects of the models
delta_y <- function(x) {
239 * log2((x + 1) / x)
}
# Create a data frame for a range of x values
x_vals <- seq(1, 20, by = 1)
effects <- delta_y(x_vals)
df <- data.frame(x = x_vals, delta_y = effects)
View(df)
# Create a data frame for a range of x values
x_vals <- seq(2, 20, by = 1)
effects <- delta_y(x_vals)
df <- data.frame(x = x_vals, delta_y = effects)
View(df)
# Create a data frame for a range of x values
x_vals <- seq(1, 20, by = 1)
effects <- delta_y(x_vals)
df <- data.frame(x = x_vals, delta_y = effects)
# Plot
ggplot(df, aes(x = x, y = delta_y)) +
geom_line(color = "blue", size = 1) +
labs(
title = "Marginal Effect of increasing Plant Species number by 1",
x = "Number of plant species (x)",
y = "Change in economic multifunctionality in € (Δy)"
) +
theme_minimal()
# Plot the predicted y as a function of the original predictor
# Define the model equation
predict_y <- function(x) {
-532 + 239 * log2(x)
}
# Create a data frame of predictor values and predicted y
y_vals <- predict_y(x_vals)
df <- data.frame(predictor = x_vals, predicted_y = y_vals)
# Plot
ggplot(df, aes(x = predictor, y = predicted_y)) +
geom_line(color = "darkgreen", size = 1) +
labs(
title = "Predicted y as a Function of Original Predictor",
x = "Original Predictor (x)",
y = "Predicted y"
) +
theme_minimal()
