dom_soc_diff <- read_xlsx("C:/Users/mm68tulo/Desktop/Jena Chapter/Data Analysis/1_Data/Dominance_Experiment/carbon+bulk_dominance_2002+2017.xlsx")  %>%
left_join(design, by = join_by(plotcode))
# join with dom_soc_diff table
dom_soc_diff <- dom_soc_diff %>%
left_join(dom_soc_02, by = "main_plot") %>%
left_join(dom_soc_17, by = "main_plot")
# create a column with annual SOC gain/loss
dom_soc_diff$Corg_diff <- (as.numeric(dom_soc_diff$Corg17) - dom_soc_diff$Corg02) / 15
# create a column with mid SOC value for beginning and end
dom_soc_diff$Corg02_val <- dom_soc_diff$Corg02 * dom_soc_diff$Bulk02 * 0.3 * 10000 / 1000 * 3.66 * 300
dom_soc_diff$Corg17_val <- dom_soc_diff$Corg17 * dom_soc_diff$dom17_bulk * 0.3 * 10000 / 1000 * 3.66 * 300
dom_soc_diff$Corg17_val <- as.numeric(dom_soc_diff$Corg17) * dom_soc_diff$dom17_bulk * 0.3 * 10000 / 1000 * 3.66 * 300
# create a column with annual SOC-value gain/loss
dom_soc_diff$Corg_val_diff <- (as.numeric(dom_soc_diff$Corg17_val) - dom_soc_diff$Corg02_val) / 15
writexl::write_xlsx(dom_soc_diff, "C:/Users/mm68tulo/Desktop/Jena Chapter/Data Analysis/1_Data/carbon+bulk_dominance_2002+2017.xlsx")
# check the relationship between plot-aggregated-SOC and sowndiv
ggplot2::ggplot(dom_soc_diff,
aes(x = sowndiv, y = Corg_val_diff)
) +
geom_point(
fill = "#28a87d",
alpha = .5
) +
labs(
x = "Species Diversity",
y = "Difference in SOC plotwise")  +
scale_x_continuous(breaks = c(1,2,3, 4,6,9))
