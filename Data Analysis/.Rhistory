biomassMeans <- biomassDat %>%
filter(year > 2018) %>%
group_by(plotcode, year, season) %>%
summarise(sum_biomass = sum(biomass, na.rm = TRUE), .groups = "drop") %>%
group_by(plotcode) %>%
summarise(mean_biomass = mean(sum_biomass, na.rm = TRUE), .groups = "drop")
View(biomassMeans)
View(biomassDat)
biomassMeans <- biomassDat %>%
filter(year > 2018) %>%
group_by(plotcode, year, season) %>%
summarise(sum_biomass = sum(biomass, na.rm = TRUE), .groups = "drop")
View(biomassMeans)
# exclude the first 5 years of the experiment
# sum up biomass for each plot and calculate mean between subsamples
biomassMeans <- biomassDat %>%
filter(year > 2018) %>%
group_by(plotcode, year, season) %>%
summarise(sum_biomass = sum(biomass, na.rm = TRUE), .groups = "drop") %>%
group_by(plotcode) %>%
summarise(mean_biomass = mean(sum_biomass, na.rm = TRUE), .groups = "drop")
synthesis <- biomassMeans %>% # merge the biomass and the realized SR data
left_join(realSRmean, by = join_by(plotcode)) #%>%
View(synthesis)
lmBio <- lm(mean_biomass ~ meanSR, synthesis) #log2 transform the x and use lmer
summary(lmBio)
plot(lmBio)
ggplot2::ggplot(synthesis,
aes(x = meanSR, y = mean_biomass)
) +
geom_point(
color = "#28a87d",
alpha = .5,
shape = "X",
stroke = 1,
size = 4
) +
geom_smooth(
method = "lm"
)
