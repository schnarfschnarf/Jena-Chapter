size = 4
) +
geom_smooth(
method = "lm"
) +
labs(
x = "log2(Sown Plant Diversity)",
y = "total benefit/costs (€/ha/a)")
lmCostsSR <- lmer(
costs_total ~ log2(sowndiv) + (1|block),
synthDat)
plot(lmCostsSR)
summary(lmCostsSR)
View(synthDat)
# check if species richness increases SOC
lmSOC <- lm(
mean_C_20 ~ log2(meanSR) + (1|block),
synthDat)
# check if species richness increases SOC
lmSOC <- lm(
mean_C_20 ~ log2(sowndiv) + (1|block),
synthDat)
# check if species richness increases SOC
lmSOC <- lmer(
mean_C_20 ~ log2(sowndiv) + (1|block),
synthDat)
summary(lmSOC)
lmSOCdiff <- lmer(
mean_org_diff ~ log2(sowndiv) + (1|block),
synthDat)
summary(lmSOCdiff)
