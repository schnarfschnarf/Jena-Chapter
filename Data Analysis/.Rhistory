synthDat)
# check if species richness increases total value
lmCostsSR <- lm(
# check if species richness increases total value
lmCostsSR <- lm(
costs_total ~ log2(as.numeric(sowndiv)),
synthDat)
plot(lmCostsSR)
# check if species richness increases total value
lmCostsSR <- lm(
costs_total ~ log2(as.numeric(sowndiv)),
synthDat)
plot(lmCostsSR)
summary(lmCostsSR)
