        <mxCell id="epCuzkumx278-8xQdCl7-1" value="&lt;font color=&quot;#66ff66&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;YIELD STABILITY&lt;/span&gt;&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
