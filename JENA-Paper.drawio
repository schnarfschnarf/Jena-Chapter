        <mxCell id="epCuzkumx278-8xQdCl7-2" value="&lt;font face=&quot;Verdana&quot; style=&quot;font-size: 25px;&quot;&gt;&lt;b style=&quot;&quot;&gt;METHODS:&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;EconMultiFun: multiplication of level of ecosystem service with accounting price&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;font face=&quot;Nr2bFoVqqSlZotRvlstI&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;font color=&quot;#f0071e&quot;&gt;Averaging approach&lt;/font&gt;: Averaging of the functions over plot and year, resulting in an index value between 0 and 1.&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;font face=&quot;HrHxR20gQMFInI2WLOZz&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;font face=&quot;Verdana&quot;&gt;Soil health: average of normalized levels of soil functions x,y,z.&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="-2890" y="474" width="437" height="432" as="geometry" />
        </mxCell>
        <mxCell id="rzhUrisrKjAXzEqFtn3z-1" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;font-size: 25px; font-family: Verdana; background-color: initial;&quot;&gt;&lt;font color=&quot;#ff9999&quot;&gt;Calculations&lt;/font&gt;:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;b&gt;Yield&lt;/b&gt;: Market prices for dry biomass weight.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;&lt;b&gt;Fodder quality:&lt;/b&gt;&amp;nbsp;Could be used as a weighting factor for biomass?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;span style=&quot;font-size: 25px;&quot;&gt;LDMC is not optimal, but a good proxy. C and N not too informative, because the quality of the fodder depends on the type of C and N compounds and their relative concentrations.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 25px; font-family: Verdana; background-color: initial;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Climate regulation through carbon sequestration:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;Mean net carbon flux per hectar and year (total SOC at the beginning of experiment - SOC in year x) * 3.66 (transformation factor from SOC to CO2)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Water quality: &lt;/b&gt;Annual net nitrogen flux (kg N/ha) with an accounting price capturing the social cost of exccess nitrogen (Fritz used 7.3€ /kg N)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Yield stability/insurance value: &lt;/b&gt;Underlying assumption has to be that plant diversity increases yield stability. &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;!!!CHECK AGAIN HOW BUCHMANN &amp;amp; FINGER DID THIS!!!!&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Pest control: &lt;/b&gt;Don&#39;t know yet.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Flood protection:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Flower cover: &lt;/b&gt;Not possible to derive € but the more, the better!&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Verdana; font-size: 25px; background-color: initial;&quot;&gt;&lt;b&gt;Pollination:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;/blockquote&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;align=left;" parent="1" vertex="1">
          <mxGeometry x="-1697" y="488" width="852" height="964" as="geometry" />
        </mxCell>
