        <mxCell id="_FUVzvGfVmQXasiZJaL7-2" value="&lt;h1 class=&quot;ecl-page-header__title&quot;&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;Soil functions are a measure of what amount a&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 17px; background-color: initial; font-weight: normal;&quot;&gt;certain soil is able to contribute to an&lt;/span&gt;&lt;/h1&gt;&lt;h1 class=&quot;ecl-page-header__title&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 17px;&quot;&gt;ecosystem services&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: initial; font-weight: normal;&quot;&gt;https://environment.ec.europa.eu/news/eu-push-increased-global-cooperation-unccd-cop16-2024-12-02_en&lt;/span&gt;&lt;br&gt;&lt;/h1&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;strokeWidth=3;fontSize=19;" parent="1" vertex="1">
