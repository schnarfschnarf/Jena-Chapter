        <mxCell id="Nqu4tQJT4MbIuSp9nCch-6" value="&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;font color=&quot;#ff9933&quot;&gt;FLOOD PROTECTION (?)&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size:11.0pt;font-family:&amp;quot;Cambria&amp;quot;,serif;&lt;br/&gt;mso-fareast-font-family:Calibri;mso-fareast-theme-font:minor-latin;mso-bidi-font-family:&lt;br/&gt;Calibri;mso-ansi-language:DE;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;Leaf&lt;br/&gt;area index + &lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;font-family:&amp;quot;Cambria&amp;quot;,serif;&lt;br/&gt;mso-fareast-font-family:Calibri;mso-fareast-theme-font:minor-latin;mso-bidi-font-family:&lt;br/&gt;Calibri;mso-ansi-language:EN-US;mso-fareast-language:EN-US;mso-bidi-language:&lt;br/&gt;AR-SA&quot; lang=&quot;EN-US&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;font-family:&amp;quot;Cambria&amp;quot;,serif;&lt;br/&gt;mso-fareast-font-family:Calibri;mso-fareast-theme-font:minor-latin;mso-bidi-font-family:&lt;br/&gt;Calibri;mso-ansi-language:DE;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;Microbial&lt;br/&gt;biomass +&lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;font-family:&amp;quot;Cambria&amp;quot;,serif;&lt;br/&gt;mso-fareast-font-family:Calibri;mso-fareast-theme-font:minor-latin;mso-bidi-font-family:&lt;br/&gt;Calibri;mso-ansi-language:EN-US;mso-fareast-language:EN-US;mso-bidi-language:&lt;br/&gt;AR-SA&quot; lang=&quot;EN-US&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;font-family:&amp;quot;Cambria&amp;quot;,serif;&lt;br/&gt;mso-fareast-font-family:Calibri;mso-fareast-theme-font:minor-latin;mso-bidi-font-family:&lt;br/&gt;Calibri;mso-ansi-language:DE;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;&lt;br/&gt;soil water content + soil infiltration rate &lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;&lt;br/&gt;font-family:Wingdings;mso-fareast-font-family:Calibri;mso-fareast-theme-font:&lt;br/&gt;minor-latin;mso-bidi-font-family:Calibri;mso-ansi-language:DE;mso-fareast-language:&lt;br/&gt;EN-US;mso-bidi-language:AR-SA&quot;&gt;à&lt;/span&gt;&lt;span style=&quot;font-size:11.0pt;&lt;br/&gt;font-family:&amp;quot;Cambria&amp;quot;,serif;mso-fareast-font-family:Calibri;mso-fareast-theme-font:&lt;br/&gt;minor-latin;mso-bidi-font-family:Calibri;mso-ansi-language:DE;mso-fareast-language:&lt;br/&gt;EN-US;mso-bidi-language:AR-SA&quot;&gt; above- and belowground water holding capacity,&lt;br/&gt;velocity of soil water uptake&lt;/span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;font color=&quot;#ff9933&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="-1654" y="-5" width="199.5" height="224" as="geometry" />
        </mxCell>
        <mxCell id="clmrfkcm1TRI9Zge-frW-1" value="&lt;h1 class=&quot;ecl-page-header__title&quot;&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;UNEP (2012) argues that 24% of the global land area has suffered declines in health&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-weight: normal; font-size: 17px;&quot;&gt;and productivity over the past quarter-century as a result of unsustainable land-use.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 17px; font-weight: 400;&quot;&gt;Since the&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 17px; font-weight: 400; background-color: initial;&quot;&gt;19th century, worldwide damage to organic matter due to land-clearing for agriculture and urban&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 17px; font-weight: 400; background-color: initial;&quot;&gt;development accounts for an estimated 60% loss of the carbon stored in soils and vegetation.&lt;/span&gt;&lt;/h1&gt;&lt;div&gt;&lt;span style=&quot;font-size: 17px; font-weight: 400; background-color: initial;&quot;&gt;(OECD F&lt;/span&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;arm Management&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 17px;&quot;&gt;Practices to Foster Green&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;Growth&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 17px; font-weight: 400; background-color: initial;&quot;&gt;&amp;nbsp;2016)&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;strokeWidth=3;fontSize=19;" parent="1" vertex="1">
          <mxGeometry x="1041" y="-1275" width="657" height="306" as="geometry" />
        </mxCell>
