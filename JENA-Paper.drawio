        <mxCell id="kZOcRY6PW7E-COzbm3XA-38" value="What are the effects on community composition turnover? Are less intensively used communities more stable?" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="-542" y="-386" width="225" height="174" as="geometry" />
        </mxCell>
        <mxCell id="nP5sV3eyKjFb3XFJXdFb-1" value="&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Verdana&quot; style=&quot;&quot; color=&quot;#f00a28&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;RASMUSSEN ET AL. 2024 (Joint environmental and social benefits from diversified agriculture)&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;OJPblVyu_FGMTrDvqpaP&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&quot;We found that applying a higher number of diversification strategies or practices had a greater likelihood of beneficial outcomes than using individual strategies or practices&quot;&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;OJPblVyu_FGMTrDvqpaP&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&quot;Positive effects of diversification strategies and practices on biodiversity were driven by effects on large, but not small, farms&quot;&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&lt;font face=&quot;OJPblVyu_FGMTrDvqpaP&quot;&gt;They found a win-loose situation for the effects of Soil Conservation practices on Biodiversity-Yield relationships&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;strokeWidth=3;fontSize=19;" parent="1" vertex="1">
          <mxGeometry x="421" y="31" width="613" height="347" as="geometry" />
        </mxCell>
        <mxCell id="nP5sV3eyKjFb3XFJXdFb-2" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 21px;&quot;&gt;&lt;font color=&quot;#f00a28&quot;&gt;Domeignoz-Horta et&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;&quot; color=&quot;#f00a28&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp;AL. 2024 (Plant diversity&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: initial; font-size: 21px;&quot;&gt;&lt;font color=&quot;#f00a28&quot;&gt;drives positive microbial associations in the rhizosphere enhancing carbon use efficiency in agricultural soils&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 21px; color: rgb(240, 10, 40); background-color: initial;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&quot; [...] increasing plant diversity strengthens positive associations within the rhizosphere soil microbial community in relation to negative associations.&amp;nbsp;These associations, in turn, enhance community carbon use efficiency&quot;&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;CAREFUL: They looked at agricultural barley fields!&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;strokeWidth=3;fontSize=19;" parent="1" vertex="1">
          <mxGeometry x="419" y="405" width="613" height="347" as="geometry" />
        </mxCell>
        <mxCell id="nP5sV3eyKjFb3XFJXdFb-3" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot; color=&quot;#f00a28&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;SCHAUB ET AL. 2020: (Plant diversity&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: initial; font-size: 21px;&quot;&gt;&lt;font color=&quot;#f00a28&quot;&gt;drives positive microbial associations in the rhizosphere enhancing carbon use efficiency in agricultural soils&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 21px; color: rgb(240, 10, 40); background-color: initial;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;&quot;Plant diversity was an&amp;nbsp; important production factor independent of management intensity, as it enhanced qualityadjusted yield and revenues similarly to increasing fertilization and cutting frequency&quot;&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;CAREFUL: There was a discussion whether these findings represent real life systems&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;strokeWidth=3;fontSize=19;" parent="1" vertex="1">
